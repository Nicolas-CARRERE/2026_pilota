# PostgreSQL connection string for Pelota API
#
# === PRODUCTION (CapRover Docker network) ===
# Use internal Docker hostname - only works from within CapRover network
PELOTA_POSTGRES_DATABASE_URL="postgresql://postgres:PASSWORD@srv-captain--bot-db:5432/2k26_pilota_bot"
#
# === DEVELOPMENT (external access) ===
# Use public URL - requires DB to be exposed publicly
# PELOTA_POSTGRES_DATABASE_URL="postgresql://postgres:PASSWORD@bot-db.tools.nicolascarrere.fr:5432/2k26_pilota_bot"
#
# === LOCAL DEV ===
# PELOTA_POSTGRES_DATABASE_URL="postgresql://user:password@localhost:5432/2k26_pilota_bot"

# FastAPI scraping service base URL (Node.js proxies scrape requests here)
PELOTA_FASTAPI_SCRAPER_SERVICE_URL="http://localhost:8001"

# Pelota API HTTP server port
PELOTA_API_SERVER_PORT=3000
