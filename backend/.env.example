# HTTP request timeout in seconds for scraper fetches
PELOTA_SCRAPER_HTTP_TIMEOUT_SECONDS=30.0

# Max retry attempts on transient failures
PELOTA_SCRAPER_MAX_RETRY_ATTEMPTS=3

# Exponential backoff factor for retries
PELOTA_SCRAPER_RETRY_BACKOFF_FACTOR=1.5

# Database connection URL for ingestion service
PELOTA_POSTGRES_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pilota

# Test mode flag - enables destructive test endpoints (NEVER enable in production)
TEST_MODE=false

# Development mode flag - alternative to TEST_MODE for local development
DEV_MODE=false
